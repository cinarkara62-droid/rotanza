generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  plan                 String    @default("free") // "free" | "pro" | "max"
  billingCycle         String? // "monthly" | "yearly"
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String? // Stripe subscription status, e.g. "active", "canceled", "past_due"
  currentPeriodEnd     DateTime?

  // Smart Travel Notifications preferences (Pro/Max only). Freeform keys:
  // "checkin" | "boarding" | "transfer" | "hotelCheckin" | "delay" | "gate"
  // | "weather" | "localTransport" -> boolean. Only the first four are
  // currently acted on by the reminders cron (see reservation-notifications
  // route) — the rest have no real data source wired up yet.
  notificationPrefs Json @default("{}")

  priceAlerts  PriceAlert[]
  reservations Reservation[]
}

model PriceAlert {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          String // "hotel" | "flight"
  name          String
  location      String
  entityId      String? // stable OSM id the hotel/route was picked from, e.g. "osm:123456"
  currentPrice  Float
  previousPrice Float
  targetPrice   Float
  lowestPrice   Float
  priceHistory  Float[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Reservation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         String // "flight" | "hotel" | "restaurant" | "activity"
  title        String
  date         DateTime
  time         String?
  confirmation String?
  notes        String?

  reminderSentAt DateTime?

  // Idempotency guards for Smart Travel Notifications — one per reminder
  // type so the cron never emails the same reminder twice.
  checkinNotifiedAt       DateTime?
  boardingNotifiedAt      DateTime?
  transferNotifiedAt      DateTime?
  hotelCheckinNotifiedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([date])
}
